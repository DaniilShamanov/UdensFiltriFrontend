# Frontend base URL for SEO links (sitemap, metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Django API base URL (no trailing slash). If served from the same domain, you can set this to /api
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Auth cookie names set by Django (HttpOnly)
NEXT_PUBLIC_AUTH_ACCESS_COOKIE=access_token
NEXT_PUBLIC_AUTH_REFRESH_COOKIE=refresh_token
NEXT_PUBLIC_AUTH_CSRF_COOKIE=csrftoken
